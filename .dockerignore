yarn-debug.log*
yarn-error.log*

# Build
.next
out
build

# Env (ใช้ค่าจาก runtime ไม่ copy .env เข้า image)
.env
.env.*
!.env.example

# Git / IDE
.git
.gitignore
.cursor
.vscode
*.md
