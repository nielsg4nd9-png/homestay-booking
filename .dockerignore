# DB files (จะ mount เป็น volume แทน)
prisma/*.db
prisma/*.db-journal

# Uploads (จะ mount เป็น volume แทน)
public/uploads

# Docs ไม่จำเป็นใน image
docs
*.txt
# scripts (ยกเว้น entrypoint สำหรับ Docker)
scripts/*
!scripts/docker-entrypoint.sh
