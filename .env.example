# ฐานข้อมูล (PostgreSQL — ใช้กับ Vercel / Docker / Neon / Supabase)
# ตัวอย่าง: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/homestay"

# NextAuth (จำเป็นสำหรับล็อกอิน)
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="สร้างค่าลับยาวๆ เช่น openssl rand -base64 32"

# --- สำหรับ Deploy บน Vercel ---
# สร้าง Storage > Blob ใน Vercel Dashboard แล้วใส่ token นี้ (ไม่งั้นอัปโหลดรูปจะ error)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ข้อมูลบัญชีรับโอน (แสดงในหน้าจอง / อัปสลิป) — ไม่บังคับ
NEXT_PUBLIC_PAYMENT_BANK_NAME=""
NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME=""
NEXT_PUBLIC_PAYMENT_ACCOUNT_NO=""
NEXT_PUBLIC_PAYMENT_PROMPTPAY_NO=""
NEXT_PUBLIC_PAYMENT_QR_IMAGE_URL=""
