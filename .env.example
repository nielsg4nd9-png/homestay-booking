# PostgreSQL เท่านั้น (Neon / Vercel Postgres / Supabase / local)
# Local: ใช้ Neon ฟรีหรือ postgres ในเครื่อง
# Deploy บน Vercel: ใช้ Neon Pooler URL + ?sslmode=require&connect_timeout=15
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# ตัวอย่าง Neon: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&connect_timeout=15

# NextAuth (จำเป็นสำหรับล็อกอิน)
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="สร้างค่าลับยาวๆ เช่น openssl rand -base64 32"

# Deploy บน Vercel — สร้าง Storage > Blob แล้วใส่ token นี้
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ข้อมูลบัญชีรับโอน (ไม่บังคับ)
NEXT_PUBLIC_PAYMENT_BANK_NAME=""
NEXT_PUBLIC_PAYMENT_ACCOUNT_NAME=""
NEXT_PUBLIC_PAYMENT_ACCOUNT_NO=""
NEXT_PUBLIC_PAYMENT_PROMPTPAY_NO=""
NEXT_PUBLIC_PAYMENT_QR_IMAGE_URL=""
